<Window x:Class="Elka_windrose_server_control.Views.ProfilePresetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Presets"
        Width="629"
        Height="953"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                     Width="16"
                     Height="16"
                     CornerRadius="4"
                     Background="#AA080604"
                     BorderBrush="#7A5A2D"
                     BorderThickness="1"
                     Margin="0,0,7,0">
                                <Path x:Name="CheckMark"
                       Data="M 2 8 L 6 12 L 14 3"
                       Stroke="#FFD98A"
                       StrokeThickness="2"
                       Visibility="Collapsed"/>
                            </Border>

                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark"
                         Property="Visibility"
                         Value="Visible"/>
                                <Setter TargetName="Box"
                         Property="BorderBrush"
                         Value="#D9A64A"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box"
                         Property="BorderBrush"
                         Value="#C8953F"/>
                                <Setter TargetName="Box"
                         Property="Background"
                         Value="#CC120B05"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FlatGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="BorderBrush" Value="#B8863B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Background="#B0120D08"
                                Padding="10"
                                Margin="0,8,0,0"/>

                            <TextBlock Text="{TemplateBinding Header}"
                                   Foreground="#FFD98A"
                                   Background="#0F0B08"
                                   FontWeight="SemiBold"
                                   Padding="8,0"
                                   Margin="14,0,0,0"
                                   HorizontalAlignment="Left"/>

                            <ContentPresenter Margin="12,20,12,12"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#44100C08"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="9"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#66160F09"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#A87932"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820150D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#CC080604"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                           Focusable="False"
                           IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                           ClickMode="Press"
                           Background="{TemplateBinding Background}"
                           BorderBrush="{TemplateBinding BorderBrush}"
                           BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                 Background="{TemplateBinding Background}"
                                 BorderBrush="{TemplateBinding BorderBrush}"
                                 BorderThickness="{TemplateBinding BorderThickness}"
                                 CornerRadius="7">
                                            <Grid>
                                                <ContentPresenter Margin="8,0,30,0"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   RecognizesAccessKey="True"/>

                                                <Path x:Name="Arrow"
                                       Data="M 0 0 L 4 4 L 8 0 Z"
                                       Fill="#D9A64A"
                                       Width="8"
                                       Height="4"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border"
                                         Property="BorderBrush"
                                         Value="#D9A64A"/>
                                                <Setter TargetName="Border"
                                         Property="Background"
                                         Value="#DD120B05"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                               IsHitTestVisible="False"
                               Content="{TemplateBinding SelectionBoxItem}"
                               ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                               ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                               Margin="8,0,30,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                            <Popup x:Name="Popup"
                    Placement="Bottom"
                    IsOpen="{TemplateBinding IsDropDownOpen}"
                    AllowsTransparency="True"
                    Focusable="False"
                    PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                       MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#120D08"
                             BorderBrush="#7A5A2D"
                             BorderThickness="1"
                             CornerRadius="7"/>
                                    <ScrollViewer Margin="2">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>




        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24">
                            <Track x:Name="PART_Track"
                           VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Height="6"
                                          Background="#D9A64A"
                                          BorderThickness="0"/>
                                </Track.DecreaseRepeatButton>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Height="6"
                                          Background="#33100C08"
                                          BorderThickness="0"/>
                                </Track.IncreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Width="18"
                                   Height="18"
                                   Background="#FFD98A"
                                   BorderBrush="#7A5A2D"
                                   BorderThickness="1"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="{TemplateBinding Background}"
                         Stroke="{TemplateBinding BorderBrush}"
                         StrokeThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <TextBlock Text="Profile World Presets"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FFD98A"/>
        </Grid>

        <Grid Grid.Row="1"
      Margin="0,16,0,16">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- PRESET -->
            <GroupBox Header="Preset"
              Grid.Row="0"
              Margin="0,0,0,14"
              Style="{StaticResource FlatGroupBoxStyle}">

                <StackPanel Margin="10">

                    <TextBlock Text="Preset Type"
                       Foreground="#FFD98A"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                    <ComboBox x:Name="PresetComboBox"
                      Height="34"
                      SelectionChanged="PresetComboBox_SelectionChanged"
                      Margin="0,0,0,14">
                        <ComboBoxItem Content="Easy"/>
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Hard"/>
                        <ComboBoxItem Content="Custom"/>
                        <ComboBoxItem Content="Default"/>
                    </ComboBox>

                    <TextBlock Text="Combat Difficulty"
                       Foreground="#FFD98A"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

                    <ComboBox x:Name="CombatDifficultyComboBox"
                      Height="34">
                        <ComboBoxItem Content="Easy"/>
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Hard"/>
                    </ComboBox>

                </StackPanel>
            </GroupBox>

            <!-- MODIFIERS -->
            <GroupBox Header="Combat Modifiers"
              Grid.Row="1"
              Margin="0,0,0,14"
              Style="{StaticResource FlatGroupBoxStyle}">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Enemy Health -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Enemy Health Modifier"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="EnemyHealthSlider"
                        Minimum="20"
                        Maximum="500"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="EnemyHealthValueTextBlock"/>
                    </StackPanel>

                    <!-- Enemy Damage -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Enemy Damage Modifier"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="EnemyDamageSlider"
                        Minimum="20"
                        Maximum="500"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="EnemyDamageValueTextBlock"/>
                    </StackPanel>

                    <!-- Ship Health -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,10">
                        <TextBlock Text="Enemy Ship Health Modifier"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="EnemyShipHealthSlider"
                        Minimum="40"
                        Maximum="500"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="EnemyShipHealthValueTextBlock"/>
                    </StackPanel>

                    <!-- Ship Damage -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,10">
                        <TextBlock Text="Enemy Ship Damage Modifier"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="EnemyShipDamageSlider"
                        Minimum="20"
                        Maximum="500"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="EnemyShipDamageValueTextBlock"/>
                    </StackPanel>

                    <!-- Boarding -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,10">
                        <TextBlock Text="Boarding Difficulty"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="BoardingDifficultySlider"
                        Minimum="20"
                        Maximum="500"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="BoardingDifficultyValueTextBlock"/>
                    </StackPanel>

                    <!-- Coop -->
                    <StackPanel Grid.Row="5" Margin="0,0,0,10">
                        <TextBlock Text="Co-op Enemy Scaling"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="CoopEnemyScalingSlider"
                        Minimum="0"
                        Maximum="200"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="CoopEnemyScalingValueTextBlock"/>
                    </StackPanel>

                    <!-- Coop Ship -->
                    <StackPanel Grid.Row="6">
                        <TextBlock Text="Co-op Ship Scaling"
                           Foreground="#FFD98A"/>
                        <Slider x:Name="CoopShipScalingSlider"
                        Minimum="0"
                        Maximum="200"
                        ValueChanged="AnyCustomValue_Changed"/>
                        <TextBlock x:Name="CoopShipScalingValueTextBlock"/>
                    </StackPanel>

                </Grid>
            </GroupBox>

            <!-- GAMEPLAY -->
            <GroupBox Header="Gameplay"
              Grid.Row="2"
              Style="{StaticResource FlatGroupBoxStyle}">

                <StackPanel Margin="10">

                    <CheckBox x:Name="ImmersiveExplorationCheckBox"
                      Content="Immersive Exploration"
                      Margin="0,0,0,10"
                      Checked="AnyCustomValue_Changed"
                      Unchecked="AnyCustomValue_Changed"/>

                    <CheckBox x:Name="SharedQuestsCheckBox"
                      Content="Shared Quests"
                      Checked="AnyCustomValue_Changed"
                      Unchecked="AnyCustomValue_Changed"/>

                    <CheckBox x:Name="SaveServerSettingsCheckBox"
          Content="Save current server settings with this profile"
          Margin="0,12,0,0"
          Checked="AnyCustomValue_Changed"
          Unchecked="AnyCustomValue_Changed"/>

                </StackPanel>
            </GroupBox>

        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Save Preset"
                    Height="38"
                    Click="SavePreset_Click"/>

            <Button Grid.Column="2"
                    Content="Apply Default"
                    Height="38"
                    Click="ApplyDefault_Click"/>

            <Button Grid.Column="4"
                    Content="Close"
                    Height="38"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>