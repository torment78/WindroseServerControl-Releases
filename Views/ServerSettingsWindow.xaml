<Window x:Class="Elka_windrose_server_control.Views.ServerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Settings"
        Height="753"
        Width="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#66110C07"/>
            <Setter Property="BorderBrush" Value="#A87932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820160C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D9A64A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA2A1B0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#CC080604"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#F5E6C8"/>
            <Setter Property="SelectionBrush" Value="#7A4A1D"/>
            <Setter Property="SelectionTextBrush" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Server Settings"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD98A"/>

                <Button Grid.Column="1"
                        Content="X"
                        Width="38"
                        Height="30"
                        Click="CloseWindow_Click"/>
            </Grid>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="20,4,20,20">
            <StackPanel>

                <TextBlock Text="Public Server Info"
                           Foreground="#FFD98A"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Server Name" Foreground="#F5E6C8"/>
                        <TextBox x:Name="ServerNameTextBox"
                                 Height="32"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Invite Code" Foreground="#F5E6C8"/>
                        <TextBox x:Name="InviteCodeTextBox"
                                 Height="32"
                                 Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Max Players" Foreground="#F5E6C8"/>
                        <TextBox x:Name="MaxPlayerCountTextBox"
                                 Height="32"
                                 Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Region" Foreground="#F5E6C8"/>
                        <TextBox x:Name="RegionTextBox"
                                 Height="32"
                                 Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="PasswordProtectedCheckBox"
                          Content="Password Protected"
                          Margin="0,0,0,8"/>

                <TextBlock Text="Password" Foreground="#F5E6C8"/>
                <TextBox x:Name="PasswordTextBox"
                         Height="32"
                         Margin="0,4,0,12"/>

                <CheckBox x:Name="AutoLoadLatestBackupIfHasBrokenCheckBox"
                          Content="Auto load latest backup if broken"
                          Margin="0,0,0,20"/>

                <TextBlock Text="Network"
                           Foreground="#FFD98A"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <CheckBox x:Name="UseDirectConnectionCheckBox"
                          Content="Use Direct Connection"
                          Margin="0,0,0,12"/>

                <TextBlock Text="P2P Proxy Address" Foreground="#F5E6C8"/>
                <TextBox x:Name="P2pProxyAddressTextBox"
                         Height="32"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Direct Connect Server Address" Foreground="#F5E6C8"/>
                <TextBox x:Name="DirectConnectionAddressTextBox"
                         Height="32"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Direct Connection Port" Foreground="#F5E6C8"/>
                <TextBox x:Name="DirectConnectionPortTextBox"
                         Height="32"
                         Margin="0,4,0,12"/>

                <TextBlock Text="Direct Connection Proxy Address" Foreground="#F5E6C8"/>
                <TextBox x:Name="ProxyAddressTextBox"
                         Height="32"
                         Margin="0,4,0,20"/>

                <Button Content="Save Settings"
                        Height="38"
                        Margin="0,40,0,0"
                        Click="SaveSettings_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>