<Window x:Class="Elka_windrose_server_control.Views.WorldBackupsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="World Backups"
        Width="640"
        Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#66110C07"/>
            <Setter Property="BorderBrush" Value="#A87932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820160C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D9A64A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA2A1B0D"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777777"/>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#44100C08"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#4A3A25"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#CC080604"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#120D08"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
             Margin="0,0,0,35"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="World Backups"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD98A"/>

                <Button Grid.Column="1"
                        Content="X"
                        Width="38"
                        Height="30"
                        Click="Close_Click"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="1"
              Margin="20,4,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="World Backups"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FFD98A"
                           Margin="0,0,0,8"/>

                <TextBlock x:Name="WorldInfoTextBlock"
                           TextWrapping="Wrap"
                           Foreground="#C8B894"
                           Margin="0,0,0,14"/>

                <Button Content="Backup Now"
                        Height="38"
                        Click="BackupNow_Click"
                        Margin="0,0,0,10"/>
            </StackPanel>

            <ListBox x:Name="BackupsListBox"
                     Grid.Row="1"
                     SelectionChanged="BackupsListBox_SelectionChanged"/>

            <Grid Grid.Row="2"
                  Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="RestoreSelectedBackupButton"
                        Grid.Column="0"
                        Content="Restore Selected Backup"
                        Height="40"
                        Click="RestoreSelectedBackup_Click"/>

                <Button Grid.Column="2"
                        Content="Close"
                        Height="40"
                        Click="Close_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>