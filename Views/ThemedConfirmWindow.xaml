<Window x:Class="Elka_windrose_server_control.Views.ThemedConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="230"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#110C08"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">

    <Border BorderBrush="#A87932"
            BorderThickness="1"
            CornerRadius="14"
            Background="#1A120C">

        <Grid Margin="18">

            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="58"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#2A1B10"
                    CornerRadius="10"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                <TextBlock x:Name="TitleTextBlock"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="#FFD98A"/>
            </Border>

            <TextBlock x:Name="MessageTextBlock"
                       Grid.Row="1"
                       Margin="10,20,10,10"
                       TextWrapping="Wrap"
                       Foreground="#F5E6C8"
                       FontSize="15"/>

            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Height="38"
                        Content="Yes"
                        Click="Yes_Click"
                        Foreground="#F5E6C8"
                        Background="#3A2414"
                        BorderBrush="#B88A44"
                        BorderThickness="1"/>

                <Button Grid.Column="2"
                        Height="38"
                        Content="No"
                        Click="No_Click"
                        Foreground="#F5E6C8"
                        Background="#241814"
                        BorderBrush="#6A4A2A"
                        BorderThickness="1"/>
            </Grid>
        </Grid>
    </Border>
</Window>