<Window x:Class="Elka_windrose_server_control.Views.DonationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Support Development"
        Width="520"
        Height="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#44100C08"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <TextBlock Text="Support Development"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FFD98A"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="4,18,4,0">
            <TextBlock Text="If you like Windrose Server Control, please consider supporting development with a coffee donation."
                       TextWrapping="Wrap"
                       Foreground="#F5E6C8"
                       FontSize="15"
                       Margin="0,0,0,14"/>

            <TextBlock Text="You can also close this window and continue using the app normally."
                       TextWrapping="Wrap"
                       Foreground="#C8B894"
                       Margin="0,0,0,18"/>

            <CheckBox x:Name="AlreadyDonatedCheckBox"
                      Content="I have already donated / do not show this again"
                      Foreground="#F5E6C8"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Open Ko-fi"
                    Height="38"
                    Click="OpenDonation_Click"/>

            <Button Grid.Column="2"
                    Content="Close"
                    Height="38"
                    Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>