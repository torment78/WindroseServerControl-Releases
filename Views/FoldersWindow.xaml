<Window x:Class="Elka_windrose_server_control.Views.FoldersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Folders"
        Width="440"
        Height="373"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#66110C07"/>
            <Setter Property="BorderBrush" Value="#A87932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820160C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D9A64A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA2A1B0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,35"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Folders"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD98A"/>

                <Button Grid.Column="1"
                        Content="X"
                        Width="38"
                        Height="30"
                        Click="Close_Click"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="20,4,20,20">

            <TextBlock Text="Open Folders"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#FFD98A"
                       Margin="0,0,0,14"/>

            <Button Content="Open Copied Server Folder"
                    Height="38"
                    Click="OpenCopiedServerFolder_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Open Backups Folder"
                    Height="38"
                    Click="OpenBackupsFolder_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Open App Logs Folder"
                    Height="38"
                    Click="OpenLogsFolder_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Open Server Logs Folder"
                    Height="38"
                    Click="OpenServerLogsFolder_Click"
                    Margin="0,0,0,18"/>

            <Button Content="Close"
                    Height="38"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>