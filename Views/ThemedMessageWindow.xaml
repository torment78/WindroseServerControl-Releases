<Window x:Class="Elka_windrose_server_control.Views.ThemedMessageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="720"
        Height="340"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#44100C08"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#66160F09"/>

                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="#A87932"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#8820150D"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <TextBlock x:Name="TitleTextBlock"
                       Margin="14,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FFD98A"/>
        </Grid>

        <!-- MESSAGE -->
        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="#66100C08"
                BorderBrush="#5A4022"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <TextBlock x:Name="MessageTextBlock"
                           TextWrapping="Wrap"
                           FontSize="15"
                           Foreground="#F5E6C8"/>

            </ScrollViewer>
        </Border>

        <!-- BUTTON -->
        <Button Grid.Row="2"
                Content="OK"
                Height="38"
                Margin="0,18,0,0"
                Click="Ok_Click"/>
    </Grid>
</Window>