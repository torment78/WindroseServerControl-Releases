<Window x:Class="Elka_windrose_server_control.Views.TailscaleSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tailscale Setup"
        Width="580"
        Height="451"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#66110C07"/>
            <Setter Property="BorderBrush" Value="#A87932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820160C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D9A64A"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA2A1B0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,35"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tailscale Setup"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD98A"/>

                <Button Grid.Column="1"
                        Content="X"
                        Width="38"
                        Height="30"
                        Click="Close_Click"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="20,4,20,20">

            <TextBlock Text="Tailscale Setup"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#FFD98A"
                       Margin="0,0,0,12"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="#C8B894"
                       Margin="0,0,0,16"
                       Text="Use this if you need external access without router port forwarding. First create/sign into a Tailscale account, then install the Windows app, then activate Funnel. If you do not trust the buttons, manually type tailscale.com into your browser." />

            <Button Content="Open Tailscale Account / Login Page"
                    Height="38"
                    Click="OpenLogin_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Download Tailscale Windows App"
                    Height="38"
                    Click="DownloadApp_Click"
                    Margin="0,0,0,8"/>

            <Button Content="Activate Funnel Permission"
                    Height="38"
                    Click="ActivateFunnel_Click"
                    Margin="0,0,0,16"/>

            <TextBlock TextWrapping="Wrap"
                       Foreground="#C8B894"
                       Text="Activate Funnel does not start your server tunnel. It runs the Tailscale Funnel command so Tailscale can open the approval page, enable HTTPS certificates, and add Funnel permission to your tailnet policy if needed." />

            <Button Content="Close"
                    Height="36"
                    Click="Close_Click"
                    Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>