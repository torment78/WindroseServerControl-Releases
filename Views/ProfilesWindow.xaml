<Window x:Class="Elka_windrose_server_control.Views.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profiles"
        Width="480"
        Height="445"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#66110C07"/>
            <Setter Property="BorderBrush" Value="#A87932"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#8820160C"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D9A64A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA2A1B0D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#CC080604"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CaretBrush" Value="#F5E6C8"/>
            <Setter Property="SelectionBrush" Value="#7A4A1D"/>
            <Setter Property="SelectionTextBrush" Value="#FFFFFF"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#CC080604"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press"
                                  Background="{TemplateBinding Background}"
                                  BorderBrush="{TemplateBinding BorderBrush}"
                                  BorderThickness="{TemplateBinding BorderThickness}">

                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="7">

                                            <Grid>
                                                <ContentPresenter Margin="8,0,30,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>

                                                <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="#D9A64A"
                                              Width="8"
                                              Height="4"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0"/>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border"
                                                Property="BorderBrush"
                                                Value="#D9A64A"/>
                                                <Setter TargetName="Border"
                                                Property="Background"
                                                Value="#DD120B05"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                      IsHitTestVisible="False"
                                      Content="{TemplateBinding SelectionBoxItem}"
                                      Margin="8,0,30,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>

                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Slide">

                                <Grid MinWidth="{TemplateBinding ActualWidth}">
                                    <Border Background="#120D08"
                                    BorderBrush="#7A5A2D"
                                    BorderThickness="1"
                                    CornerRadius="7"/>

                                    <ScrollViewer Margin="2">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#120D08"/>
            <Setter Property="Padding" Value="8,5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                        Background="{TemplateBinding Background}"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder"
                                Property="Background"
                                Value="#5A3517"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder"
                                Property="Background"
                                Value="#7A4A1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,35"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Profiles"
                           VerticalAlignment="Center"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#FFD98A"/>

                <Button Grid.Column="1"
                        Content="X"
                        Width="38"
                        Height="30"
                        Click="Close_Click"/>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="20,4,20,20">

            <TextBlock Text="Profile Name"
                       Foreground="#F5E6C8"
                       Margin="0,0,0,4"/>

            <TextBox x:Name="ProfileNameTextBox"
                     Height="32"
                     Margin="0,0,0,10"/>
            <Button Content="Profile Presets"
        Height="36"
        Click="ProfilePresets_Click"
        Margin="0,0,0,14"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Save Profile"
                        Height="34"
                        Click="SaveProfile_Click"/>

                <Button Grid.Column="2"
                        Content="Refresh"
                        Height="34"
                        Click="Refresh_Click"/>
            </Grid>

            <TextBlock Text="Saved Profiles"
                       Foreground="#F5E6C8"
                       Margin="0,0,0,4"/>

            <ComboBox x:Name="ProfilesComboBox"
                      Height="34"
                      SelectionChanged="ProfilesComboBox_SelectionChanged"
                      Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Load Profile"
                        Height="34"
                        Click="LoadProfile_Click"/>

                <Button Grid.Column="2"
                        Content="Delete Profile"
                        Height="34"
                        Click="DeleteProfile_Click"/>
            </Grid>

            <TextBlock x:Name="ActiveProfileTextBlock"
                       Text="Active profile: Active ServerDescription.json"
                       Foreground="#F5E6C8"
                       TextWrapping="Wrap"
                       Margin="0,0,0,14"/>

            <Button Content="Close"
                    Height="36"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>