<Window x:Class="Elka_windrose_server_control.Views.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="App Update"
        Width="620"
        Height="454"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#0F0B08"
        Foreground="#F5E6C8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F5E6C8"/>
            <Setter Property="Background" Value="#44100C08"/>
            <Setter Property="BorderBrush" Value="#7A5A2D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border Background="#AA080604"
                    BorderBrush="#A87932"
                    BorderThickness="1"
                    CornerRadius="10"/>

            <TextBlock Text="Update Available"
                       VerticalAlignment="Center"
                       Margin="14,0,0,0"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#FFD98A"/>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="4,18,4,0">

            <TextBlock x:Name="VersionTextBlock"
                       Foreground="#FFD98A"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"/>

            <Border Background="#66100C08"
                    BorderBrush="#5A4022"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Height="190">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="NotesTextBlock"
                               TextWrapping="Wrap"
                               Foreground="#F5E6C8"/>
                </ScrollViewer>
            </Border>
<ProgressBar x:Name="DownloadProgressBar"
             Height="16"
             Minimum="0"
             Maximum="100"
             Value="0"
             Visibility="Collapsed"
             Margin="0,14,0,0"/>

<TextBlock x:Name="DownloadStatusTextBlock"
           Text=""
           Foreground="#C8B894"
           Margin="0,6,0,0"/>
            <TextBlock Text="The installer will update the app files only. Your server files, worlds, profiles, backups, SteamCMD tools, and data folders are preserved."
                       TextWrapping="Wrap"
                       Foreground="#C8B894"
                       Margin="0,14,0,0"/>
        </StackPanel>

        <Grid Grid.Row="2"
              Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="Download / Install"
                    Height="38"
                    Click="Install_Click"/>

            <Button Grid.Column="2"
        Content="Skip Version"
        Height="38"
        Click="Skip_Click"/>

            <Button Grid.Column="4"
        Content="Later"
        Height="38"
        Click="Later_Click"/>
        </Grid>
    </Grid>
</Window>